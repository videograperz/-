function setTimer(secs) {
    secs = parseInt(secs, 10);
    if (!Number.isFinite(secs) || secs < 1 || secs > 30) return;
    timerSeconds = secs;
    localStorage.setItem('timerSeconds', secs);
    updateTimerUI();
    showMsg('timer-save-msg', `вң… ${secs}мҙҲлЎң м„Өм •лҗҳм—ҲмҠөлӢҲлӢӨ!`);
}

function setTimerCustom() {
    const val = parseInt(document.getElementById('timer-custom').value);
    if (!val || val < 1 || val > 30) { alert('1~30 мӮ¬мқҙмқҳ мҲ«мһҗлҘј мһ…л Ҙн•ҙмЈјм„ёмҡ”'); return; }
    setTimer(val);
    document.getElementById('timer-custom').value = '';
}

function setShootCount(n) {
    n = parseInt(n, 10);
    if (![3, 4, 6, 8, 10].includes(n)) return;
    shootCount = n;
    localStorage.setItem('shootCount', n);
    updateCountUI();
    showMsg('count-save-msg', `вң… ${n}мһҘмңјлЎң м„Өм •лҗҳм—ҲмҠөлӢҲлӢӨ!`);
}

function updateTimerUI() {
    document.querySelectorAll('.timer-btn').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.secs) === timerSeconds);
    });
}

function updateCountUI() {
    document.querySelectorAll('.count-btn').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.count) === shootCount);
    });
}

// ============================
//  ADMIN вҖ” GENERAL
// ============================
function showAdminLogin() {
    document.getElementById('admin-pw-input').value = '';
    document.getElementById('admin-login-error').style.display = 'none';
    showScreen('admin-login');
    setTimeout(() => document.getElementById('admin-pw-input').focus(), 300);
}

function adminLogin() {
    if (document.getElementById('admin-pw-input').value === adminPw) {
        document.getElementById('admin-title-input').value = appTitle;
        renderAdminFrameList();
        updateStorageInfo();
        updateTimerUI();
        updateCountUI();
        showScreen('admin');
    } else {
        const errEl = document.getElementById('admin-login-error');
        errEl.style.display = 'block'; errEl.textContent = 'л№„л°ҖлІҲнҳёк°Җ нӢҖл ёмҠөлӢҲлӢӨ';
        document.getElementById('admin-pw-input').value = '';
        document.getElementById('admin-pw-input').focus();
    }
}

async function handleFrameUpload(event) {
    const files = event.target.files;
    if (!files || !files.length) return;
    for (const file of files) {
        if (!file.type.startsWith('image/')) continue;
        let dataUrl;
        try {
            dataUrl = await resizeImage(file, 1000);
        } catch(e) { alert('мқҙлҜём§Җ мІҳлҰ¬ мӨ‘ мҳӨлҘҳк°Җ л°ңмғқн–ҲмҠөлӢҲлӢӨ: ' + file.name); continue; }
        if (!isSafeFrameDataUrl(dataUrl)) {
            alert('м§Җмӣҗн•ҳм§Җ м•ҠлҠ” мқҙлҜём§Җ нҳ•мӢқмһ…лӢҲлӢӨ: ' + file.name);
            continue;
        }
        const newFrame = { id: 'cf-' + Date.now() + '-' + Math.random().toString(36).substr(2,6),
                           name: sanitizePlainText(file.name.replace(/\.[^.]+$/, ''), 20) || 'м¶”к°Җ н”„л Ҳмһ„', dataUrl };
        customFrames.push(newFrame);
        try {
            localStorage.setItem('customFrames', JSON.stringify(customFrames));
        } catch(e) {
            // м ҖмһҘ мӢӨнҢЁ мӢң л©”лӘЁлҰ¬м—җм„ңлҸ„ мҰүмӢң м ңкұ°н•ҙ л¶Ҳмқјм№ҳ л°©м§Җ
            customFrames.pop();
            alert('м ҖмһҘ кіөк°„мқҙ л¶ҖмЎұн•©лӢҲлӢӨ! "' + file.name + '" нҢҢмқјмқ„ м¶”к°Җн•  мҲҳ м—ҶмҠөлӢҲлӢӨ.');
        }
    }
    renderAdminFrameList(); updateStorageInfo(); event.target.value = '';
}

function deleteFrame(id) {
    if (!confirm('мқҙ н”„л Ҳмһ„мқ„ мӮӯм ңн•ҳмӢңкІ мҠөлӢҲк№Ң?')) return;
    customFrames = customFrames.filter(f => f.id !== id);
    try { localStorage.setItem('customFrames', JSON.stringify(customFrames)); } catch(e) {}
    renderAdminFrameList(); updateStorageInfo();
}

function renderAdminFrameList() {
    const container = document.getElementById('admin-frame-list');
    container.innerHTML = '';
    if (customFrames.length === 0) {
        container.innerHTML = '<div class="text-center py-6 text-gray-300 text-sm">м—…лЎңл“ңлҗң н”„л Ҳмһ„мқҙ м—ҶмҠөлӢҲлӢӨ<br>мң„ лІ„нҠјмңјлЎң мқҙлҜём§ҖлҘј м¶”к°Җн•ҙліҙм„ёмҡ”</div>';
        return;
    }
    customFrames.forEach(f => {
        const item = document.createElement('div');
        item.className = 'frame-admin-item';

        const img = document.createElement('img');
        img.src = f.dataUrl;
        img.alt = f.name;
        item.appendChild(img);

        const info = document.createElement('div');
        info.className = 'flex-1 min-w-0';
        const name = document.createElement('div');
        name.className = 'font-semibold text-sm text-gray-700 truncate';
        name.textContent = f.name;
        const size = document.createElement('div');
        size.className = 'text-xs text-gray-400';
        size.textContent = formatBytes(f.dataUrl.length);
        info.appendChild(name);
        info.appendChild(size);
        item.appendChild(info);

        const del = document.createElement('button');
        del.className = 'text-red-400 hover:text-red-600 hover:bg-red-50 px-3 py-2 rounded-lg text-sm font-medium transition-all flex-shrink-0';
        del.textContent = 'мӮӯм ң';
        del.onclick = () => deleteFrame(f.id);
        item.appendChild(del);

        container.appendChild(item);
    });
}

function updateStorageInfo() {
    const el = document.getElementById('storage-info');
    try { el.textContent = `м ҖмһҘ кіөк°„ мӮ¬мҡ©: ${formatBytes(new Blob(Object.values(localStorage)).size)}`; }
    catch(e) { el.textContent = ''; }
}

function changePassword() {
    const newPw = document.getElementById('admin-new-pw').value.trim();
    if (!newPw) { alert('мғҲ л№„л°ҖлІҲнҳёлҘј мһ…л Ҙн•ҙмЈјм„ёмҡ”'); return; }
    if (newPw.length < 2) { alert('л№„л°ҖлІҲнҳёлҠ” 2мһҗ мқҙмғҒмқҙм–ҙм•ј н•©лӢҲлӢӨ'); return; }
    adminPw = newPw;
    localStorage.setItem('adminPw', adminPw);
    document.getElementById('admin-new-pw').value = '';
    showMsg('pw-change-msg', 'вң… л№„л°ҖлІҲнҳёк°Җ ліҖкІҪлҗҳм—ҲмҠөлӢҲлӢӨ!');
}

function resetAll() {
    if (!confirm('м •л§җлЎң лӘЁл“  м„Өм •мқ„ мҙҲкё°нҷ”н•ҳмӢңкІ мҠөлӢҲк№Ң?\n\nвҖў л©”мқё нғҖмқҙнӢҖ вҶ’ "Grace Frame"\nвҖў лӘЁл“  м—…лЎңл“ң н”„л Ҳмһ„ мӮӯм ң\nвҖў л№„л°ҖлІҲнҳё вҶ’ "0000"\nвҖў нғҖмқҙлЁё вҶ’ 3мҙҲ\nвҖў мҙ¬мҳҒ мһҘмҲҳ вҶ’ 3мһҘ')) return;
    if (!confirm('вҡ пёҸ мқҙ мһ‘м—…мқҖ лҗҳлҸҢлҰҙ мҲҳ м—ҶмҠөлӢҲлӢӨ. кі„мҶҚн•ҳмӢңкІ мҠөлӢҲк№Ң?')) return;

    ['appTitle','customFrames','adminPw','timerSeconds','shootCount'].forEach(k => localStorage.removeItem(k));
    appTitle = 'Grace Frame'; customFrames = []; adminPw = '0000'; timerSeconds = 3; shootCount = 3;

    refreshTitle(); renderAdminFrameList(); updateStorageInfo(); updateTimerUI(); updateCountUI();
    alert('мҙҲкё°нҷ”к°Җ мҷ„лЈҢлҗҳм—ҲмҠөлӢҲлӢӨ!');
}

// ============================
//  INITIALIZATION
// ============================
function init() {
    refreshTitle();
    document.addEventListener('touchstart', e => { if (e.touches.length > 1) e.preventDefault(); }, { passive: false });
    document.addEventListener('keydown', e => {
        if (e.key !== 'Escape') return;
        const screens = ['screen-result','screen-photo-select','screen-camera','screen-frames','screen-admin','screen-admin-login'];
        for (const s of screens) {
            const el = document.getElementById(s);
            if (el && el.classList.contains('active')) {
                if (s === 'screen-camera' && isCapturing) return;
                goHome(); return;
            }
        }
    });
}

init();
</script>
