async function generateStripCanvas() {
    if (selectedLayout === 'grid') return await generateGridCanvas();
    await document.fonts.ready;

    // BUG FIX: photoOrient was ignored вҖ” always used 4:3 slots even for portrait photos
    const isPortrait = (photoOrient === 'portrait');
    const photoW = 420;
    const photoH = isPortrait ? Math.round(photoW * 4 / 3) : Math.round(photoW * 3 / 4); // 560 or 315
    const gap = 10, padX = 28, topH = 72, bottomH = 72;
    const photoCount = STRIP_PHOTO_COUNT;
    const W = photoW + 2 * padX;
    const H = topH + photoCount * photoH + (photoCount - 1) * gap + bottomH;
    const canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');

    const df = DEFAULT_FRAMES.find(f => f.id === selectedFrameId);
    const cf = customFrames.find(f => f.id === selectedFrameId);
    let textColor = '#333333', subTextColor = '#999999';

    if (df) {
        const grad = ctx.createLinearGradient(0, 0, 0, H);
        grad.addColorStop(0, df.colors[0]); grad.addColorStop(1, df.colors[1]);
        ctx.fillStyle = grad; ctx.fillRect(0, 0, W, H);
        textColor = df.textColor; subTextColor = df.textColor;
    } else if (cf) {
        try { ctx.drawImage(await loadImage(cf.dataUrl), 0, 0, W, H); }
        catch(e) { ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, W, H); }
        textColor = '#ffffff'; subTextColor = '#ffffffbb';
        ctx.fillStyle = 'rgba(0,0,0,0.22)';
        ctx.fillRect(0, 0, W, topH);
        ctx.fillRect(0, H - bottomH, W, bottomH);
    } else {
        ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, W, H);
    }

    // мӮ¬м§„ 3мһҘ вҖ” м„ёлЎңлЎң мҢ“кё° (photoOrientм—җ л§һлҠ” л№„мңЁлЎң)
    for (let i = 0; i < photoCount; i++) {
        const x = padX;
        const y = topH + i * (photoH + gap);

        ctx.save();
        ctx.shadowColor = 'rgba(0,0,0,0.15)'; ctx.shadowBlur = 14; ctx.shadowOffsetY = 4;
        ctx.fillStyle = '#ffffff';
        roundRect(ctx, x, y, photoW, photoH, 8); ctx.fill();
        ctx.restore();

        if (capturedPhotos[i]) {
            ctx.save();
            roundRect(ctx, x, y, photoW, photoH, 8); ctx.clip();
            drawCover(ctx, capturedPhotos[i], x, y, photoW, photoH);
            ctx.restore();
        }

        ctx.save();
        ctx.strokeStyle = 'rgba(255,255,255,0.35)'; ctx.lineWidth = 1;
        roundRect(ctx, x, y, photoW, photoH, 8); ctx.stroke();
        ctx.restore();
    }

    // нғҖмқҙнӢҖ (мғҒлӢЁ мӨ‘м•ҷ)
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillStyle = textColor;
    ctx.font = `900 30px "Noto Sans KR", sans-serif`;
    ctx.fillText(appTitle, W / 2, topH / 2);

    // кө¬л¶„м„ 
    ctx.strokeStyle = textColor; ctx.globalAlpha = 0.15; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(W/2-44, topH-10); ctx.lineTo(W/2+44, topH-10); ctx.stroke();
    ctx.globalAlpha = 1;

    // лӮ м§ң (н•ҳлӢЁ мӨ‘м•ҷ) вҖ” BUG FIX: padYлҘј л”°лЎң м“°л©ҙм„ң bottomYк°Җ м–ҙкёӢлӮ¬лҚҳ кІғ мҲҳм •
    const now = new Date();
    const ds = `${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')}`;
    ctx.font = '400 16px "Noto Sans KR", sans-serif';
    ctx.fillStyle = subTextColor; ctx.globalAlpha = 0.7;
    ctx.fillText(ds, W / 2, H - bottomH / 2);
    ctx.globalAlpha = 1;
    return canvas;
}

async function generateGridCanvas() {
    await document.fonts.ready;

    // BUG FIX: photoOrient was ignored here too
    const isPortrait = (photoOrient === 'portrait');
    const photoW = isPortrait ? 204 : 272;
    const photoH = isPortrait ? 272 : 204; // 3:4 or 4:3
    const gapX = 14, gapY = 14, padX = 28, topH = 76, bottomH = 60;
    const W = 2 * photoW + gapX + 2 * padX;
    const H = topH + 2 * photoH + gapY + bottomH;
    const canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');

    const df = DEFAULT_FRAMES.find(f => f.id === selectedFrameId);
    const cf = customFrames.find(f => f.id === selectedFrameId);
    let textColor = '#333333', subTextColor = '#999999';

    if (df) {
        const grad = ctx.createLinearGradient(0, 0, 0, H);
        grad.addColorStop(0, df.colors[0]); grad.addColorStop(1, df.colors[1]);
        ctx.fillStyle = grad; ctx.fillRect(0, 0, W, H);
        textColor = df.textColor; subTextColor = df.textColor;
    } else if (cf) {
        try { ctx.drawImage(await loadImage(cf.dataUrl), 0, 0, W, H); }
        catch(e) { ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, W, H); }
        textColor = '#ffffff'; subTextColor = '#ffffffbb';
        ctx.fillStyle = 'rgba(0,0,0,0.18)';
        ctx.fillRect(0, 0, W, topH);
        ctx.fillRect(0, H - bottomH, W, bottomH);
    } else {
        ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, W, H);
    }

    for (let i = 0; i < GRID_PHOTO_COUNT; i++) {
        const col = i % 2, row = Math.floor(i / 2);
        const x = padX + col * (photoW + gapX);
        const y = topH + row * (photoH + gapY);

        ctx.save();
        ctx.shadowColor = 'rgba(0,0,0,0.13)'; ctx.shadowBlur = 10; ctx.shadowOffsetY = 3;
        ctx.fillStyle = '#ffffff';
        roundRect(ctx, x, y, photoW, photoH, 8); ctx.fill();
        ctx.restore();

        if (capturedPhotos[i]) {
            ctx.save();
            roundRect(ctx, x, y, photoW, photoH, 8); ctx.clip();
            drawCover(ctx, capturedPhotos[i], x, y, photoW, photoH); // вҳ… 4:3 нҒ¬лЎӯлҗң мӮ¬м§„ вҶ’ кҪү мұ„мӣҖ
            ctx.restore();
        }

        ctx.save();
        ctx.strokeStyle = 'rgba(255,255,255,0.4)'; ctx.lineWidth = 1;
        roundRect(ctx, x, y, photoW, photoH, 8); ctx.stroke();
        ctx.restore();
    }

    ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillStyle = textColor;
    ctx.font = '900 32px "Noto Sans KR", sans-serif';
    ctx.fillText(appTitle, W / 2, topH / 2 - 2);

    ctx.strokeStyle = textColor; ctx.globalAlpha = 0.15; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(W/2-44, topH-12); ctx.lineTo(W/2+44, topH-12); ctx.stroke();
    ctx.globalAlpha = 1;

    const now = new Date();
    const ds = `${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')}`;
    ctx.font = '400 16px "Noto Sans KR", sans-serif';
    ctx.fillStyle = subTextColor; ctx.globalAlpha = 0.7;
    ctx.fillText(ds, W / 2, H - bottomH / 2);
    ctx.globalAlpha = 1;
    return canvas;
}

