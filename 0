async function goToCamera() {
    if (!selectedFrameId) return;
    showScreen('camera');
    capturedPhotos = new Array(getActualShootCount()).fill(null);
    currentShot = 0; stripDataUrl = null; isCapturing = false;
    updateSlots();
    const btn = document.getElementById('btn-start-capture');
    btn.style.display = 'block'; btn.disabled = true;
    document.getElementById('camera-status').textContent = 'м№ҙл©”лқј мӨҖл№„ мӨ‘...';
    await startCameraStream();
}

async function startCameraStream() {
    stopCamera();
    const video = document.getElementById('camera-video');
    video.className = facingMode === 'user' ? 'mirrored' : '';
    const startBtn = document.getElementById('btn-start-capture');
    startBtn.disabled = true;  // мҠӨнҠёлҰј мӢңмһ‘ м „ н•ӯмғҒ л№„нҷңм„ұнҷ”
    try {
        mediaStream = await navigator.mediaDevices.getUserMedia({
            video: { facingMode, width: { ideal: 1920 }, height: { ideal: 1080 } },
            audio: false
        });
        video.srcObject = mediaStream;
        await video.play();
        document.getElementById('camera-status').textContent = 'мӨҖл№„ мҷ„лЈҢ! мҙ¬мҳҒ мӢңмһ‘мқ„ лҲҢлҹ¬мЈјм„ёмҡ”';
        // isCapturing мӨ‘мқҙл©ҙ мһ¬нҷңм„ұнҷ”н•ҳм§Җ м•ҠмқҢ (кІҪмҹҒ мЎ°кұҙ л°©м–ҙ)
        if (!isCapturing) startBtn.disabled = false;
        document.getElementById('btn-flip-camera').style.display = 'flex';
    } catch(err) {
        document.getElementById('camera-status').textContent = 'вҡ пёҸ м№ҙл©”лқјлҘј мӮ¬мҡ©н•  мҲҳ м—ҶмҠөлӢҲлӢӨ';
        console.error('Camera error:', err);
        alert('м№ҙл©”лқј мҳӨлҘҳ: ' + err.message + '\n\nм№ҙл©”лқј к¶Ңн•ңмқ„ н—Ҳмҡ©н•ҳкі  HTTPSм—җм„ң мӢӨн–үн•ҙмЈјм„ёмҡ”.');
    }
}

async function flipCamera() {
    if (isCapturing) return;
    facingMode = facingMode === 'user' ? 'environment' : 'user';
    document.getElementById('btn-flip-camera').style.opacity = '0.5';
    await startCameraStream();
    document.getElementById('btn-flip-camera').style.opacity = '1';
}

function stopCamera() {
    if (mediaStream) { mediaStream.getTracks().forEach(t => t.stop()); mediaStream = null; }
    const video = document.getElementById('camera-video');
    if (video) video.srcObject = null;
}

// лҸҷм Ғ нҸ¬нҶ мҠ¬лЎҜ л ҢлҚ”л§Ғ
function updateSlots() {
    const N = getActualShootCount();
    const row = document.getElementById('photo-slots-row');
    if (!row) return;

    // нҷ”л©ҙ нҸӯм—җ л§һкІҢ мҠ¬лЎҜ нҒ¬кё° мһҗлҸҷ кі„мӮ°
    const avail = Math.min(window.innerWidth, 480) - 24 - (N - 1) * 6;
    let w = Math.max(36, Math.min(68, Math.floor(avail / N)));
    const h = Math.round(w * 0.75);

    row.innerHTML = '';
    for (let i = 0; i < N; i++) {
        const slot = document.createElement('div');
        slot.id = 'ps-' + i;
        slot.className = 'photo-slot';
        slot.style.cssText = `width:${w}px;height:${h}px;`;

        if (capturedPhotos[i]) {
            slot.classList.add('captured');
            const img = document.createElement('img');
            img.src = capturedPhotos[i].src;
            slot.appendChild(img);
        } else if (i === currentShot && isCapturing) {
            slot.classList.add('active');
            slot.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;color:#ec4899;font-size:10px;font-weight:900;">${i+1}</div>`;
        } else {
            slot.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;color:rgba(255,255,255,0.25);font-size:10px;font-weight:700;">${i+1}</div>`;
        }
        row.appendChild(slot);
    }
}

