async function startCapture() {
    if (isCapturing) return;
    isCapturing = true;
    document.getElementById('btn-start-capture').style.display = 'none';
    // BUG FIX: flip button should be visually disabled during capture
    const flipBtn = document.getElementById('btn-flip-camera');
    if (flipBtn) { flipBtn.style.opacity = '0.3'; flipBtn.style.pointerEvents = 'none'; }

    const totalShots = getActualShootCount();
    const outputPhotos = getOutputPhotoCount();

    for (let i = 0; i < totalShots; i++) {
        currentShot = i;
        updateSlots();
        document.getElementById('camera-status').textContent = `${i + 1}лІҲм§ё мӮ¬м§„ мӨҖл№„! рҹ“ё`;
        await sleep(1200);

        const cdEl = document.getElementById('countdown-display');
        for (let c = timerSeconds; c >= 1; c--) {
            cdEl.style.display = 'flex';
            cdEl.innerHTML = `<span class="countdown-number">${c}</span>`;
            playBeep(c === 1 ? 1300 : 880, 200);
            await sleep(1000);
        }
        cdEl.style.display = 'none';

        await capturePhoto(i);
        triggerFlash();
        playBeep(1600, 100);
        await sleep(50);
        playBeep(2000, 100);

        updateSlots();
        document.getElementById('camera-status').textContent = `${i + 1}/${totalShots} мҙ¬мҳҒ мҷ„лЈҢ! вң…`;
        if (i < totalShots - 1) await sleep(1800);
    }

    document.getElementById('camera-status').textContent = 'лӘЁл“  мӮ¬м§„ мҙ¬мҳҒ мҷ„лЈҢ! рҹҺү';
    isCapturing = false;
    if (flipBtn) { flipBtn.style.opacity = '1'; flipBtn.style.pointerEvents = ''; }
    await sleep(800);
    stopCamera();

    if (totalShots > outputPhotos) {
        showPhotoSelectScreen();
    } else {
        await generateAndShowResult();
    }
}

// BUG FIX: photoOrient was declared but NEVER used here вҖ” always captured 4:3 regardless of setting
function capturePhoto(idx) {
    return new Promise(resolve => {
        const video = document.getElementById('camera-video');
        const vw = video.videoWidth, vh = video.videoHeight;
        if (!vw || !vh) { resolve(); return; }

        // photoOrient м—җ л”°лқј нҒ¬лЎӯ л№„мңЁ кІ°м •
        const targetRatio = (photoOrient === 'portrait') ? (3 / 4) : (4 / 3);
        const videoRatio  = vw / vh;
        let sx, sy, sw, sh;
        if (videoRatio > targetRatio) {
            // л№„л””мҳӨк°Җ лҚ” л„“мқҢ вҶ’ мўҢмҡ°лҘј мһҗлҰ„
            sh = vh; sw = vh * targetRatio;
            sy = 0;  sx = (vw - sw) / 2;
        } else {
            // л№„л””мҳӨк°Җ лҚ” мўҒмқҢ вҶ’ мң„м•„лһҳлҘј мһҗлҰ„
            sw = vw; sh = vw / targetRatio;
            sx = 0;  sy = (vh - sh) / 2;
        }
        const outW = Math.round(sw), outH = Math.round(sh);
        const c = document.createElement('canvas');
        c.width = outW; c.height = outH;
        const cx = c.getContext('2d');
        if (facingMode === 'user') {
            cx.translate(outW, 0); cx.scale(-1, 1);
        }
        cx.drawImage(video, sx, sy, sw, sh, 0, 0, outW, outH);
        const img = new Image();
        img.onload = () => { capturedPhotos[idx] = img; resolve(); };
        img.src = c.toDataURL('image/jpeg', 0.92);
    });
}

