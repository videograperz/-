    const strip = document.createElement('div');
    const isGrid = selectedLayout === 'grid';
    strip.style.cssText = isGrid
        ? 'width:84px;padding:8px;background:rgba(255,255,255,0.32);border-radius:7px;box-shadow:0 4px 16px rgba(0,0,0,0.08);'
        : 'width:50px;padding:6px;background:rgba(255,255,255,0.32);border-radius:7px;box-shadow:0 4px 16px rgba(0,0,0,0.08);';

    const mark = document.createElement('div');
    mark.style.cssText = `height:5px;background:${frame.textColor};opacity:0.38;border-radius:2px;width:${isGrid ? '55%' : '70%'};margin:0 auto 5px;`;
    strip.appendChild(mark);

    const slots = document.createElement('div');
    slots.style.cssText = isGrid
        ? 'display:grid;grid-template-columns:1fr 1fr;gap:4px;'
        : 'display:flex;flex-direction:column;gap:4px;';
    const count = isGrid ? GRID_PHOTO_COUNT : STRIP_PHOTO_COUNT;
